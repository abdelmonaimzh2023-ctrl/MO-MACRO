<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MO MACRO"
            android:textSize="32sp"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Multi-Dot Control Panel"
            android:textSize="14sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginBottom="40dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/panel_bg"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_status_overlay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="● Stopped"
                    android:textSize="16sp"
                    android:textColor="#888888" />

                <Button
                    android:id="@+id/btn_toggle_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Start Widgets"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:backgroundTint="#4CAF50"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_hint_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap to start"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/panel_bg"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_status_accessibility"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="● Not Enabled"
                    android:textSize="16sp"
                    android:textColor="#FF9800" />

                <Button
                    android:id="@+id/btn_accessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Enable"
                    android:textSize="14sp"
                    android:textColor="@color/dark_bg"
                    android:backgroundTint="#FF9800"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_hint_accessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Required"
                android:textSize="12sp"
                android:textColor="#FF9800"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_add_dot"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="➕ Add New Dot"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:backgroundTint="#00BCD4"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⚙ Settings"
            android:textSize="16sp"
            android:textColor="@color/dark_bg"
            android:backgroundTint="@color/white"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MO MACRO • com.monaim.studio • v3.0"
            android:textSize="10sp"
            android:textColor="#44FFFFFF"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
